# EFTPOS/Online EFTPOS payment channel configuration
# Copy needed keys into your runtime env file (for example .env.local)

# EFTPOS provider API base URL, for example: https://api.your-provider.com
EFTPOS_API_BASE_URL=

# EFTPOS provider API bearer token
EFTPOS_API_TOKEN=

# Optional but recommended for webhook signature verification
EFTPOS_WEBHOOK_SECRET=
