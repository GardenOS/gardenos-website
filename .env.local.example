# 复制为 .env.local 后填写（勿提交 .env.local）

# Clerk（Dashboard → Webhooks → Signing Secret）
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxx

# Clerk Auth（建议生产环境务必配置，避免 keyless mode 回跳异常）
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxx
# CLERK_SECRET_KEY=sk_live_xxxxxxxx
# 可选：强制登录后回到固定路径（避免来源 URL 带来跨域回跳）
# NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=https://mygardenos.com/zh/dashboard
# NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=https://mygardenos.com/zh/dashboard

# Airtable（注册页表单写入）
AIRTABLE_ACCESS_TOKEN=pat_xxxxxxxx
AIRTABLE_BASE_ID=app_xxxxxxxx
# 可选：默认优先写入 Registrations；留空时也会回退查找 Leads
AIRTABLE_TABLE_NAME=Registrations

# Resend（注册确认 / RSVP 邮件）
RESEND_API_KEY=re_xxxxxxxx
# 建议使用已在 Resend 验证过的发件地址
EMAIL_FROM=GardenOS <noreply@your-domain.com>

# 邮件里的图片和链接需要可公开访问的站点地址。
# 本地开发若保留 localhost，收件人的邮箱客户端通常无法加载图片。
NEXT_PUBLIC_SITE_URL=https://your-public-site.example

# R2 公共访问前缀（浏览器直读对象，用于 dashboard/scan LAS 预览）
# NEXT_PUBLIC_R2_PUBLIC_URL=https://your-bucket.r2.dev

# Neon/PostgreSQL（后端数据库）
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# 可选：兼容不同工具链
PGHOST=your-pooler-host
PGHOST_UNPOOLED=your-direct-host
PGUSER=your-user
PGDATABASE=your-database
PGPASSWORD=your-password

POSTGRES_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
POSTGRES_USER=your-user
POSTGRES_HOST=your-host
POSTGRES_PASSWORD=your-password
POSTGRES_DATABASE=your-database
POSTGRES_URL_NO_SSL=postgresql://USER:PASSWORD@HOST/DATABASE
POSTGRES_PRISMA_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Live backend admin allowlist (Clerk User IDs, comma-separated)
LIVE_ADMIN_USER_IDS=user_xxx,user_yyy

# Payments (multi-channel)
# Optional channel-specific templates:
# - .env.payment.stripe.example
# - .env.payment.eftpos.example
# - .env.payment.mock.example

# Stripe (for apple_pay, card)
STRIPE_SECRET_KEY=
# Strongly recommended for webhook signature verification
STRIPE_WEBHOOK_SECRET=

# Online EFTPOS channel
EFTPOS_API_BASE_URL=
EFTPOS_API_TOKEN=
# Strongly recommended for webhook signature verification
EFTPOS_WEBHOOK_SECRET=

# Mock fallback (set false when production channels are fully ready)
PAYMENT_ALLOW_MOCK_FALLBACK=true
